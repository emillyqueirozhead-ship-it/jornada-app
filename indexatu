<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>JornadaApp — Controle de Jornada e Banco de Horas</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --c1: #185FA5;
      --c1l: #E6F1FB;
      --c1t: #0C447C;
      --c2: #0F6E56;
      --c2l: #E1F5EE;
      --c2t: #085041;
      --cr: #A32D2D;
      --crl: #FCEBEB;
      --ca: #BA7517;
      --cal: #FAEEDA;
      --cg: #3B6D11;
      --cgl: #EAF3DE;
      --bg: #F5F5F3;
      --surface: #FFFFFF;
      --border: rgba(0,0,0,0.1);
      --border-md: rgba(0,0,0,0.18);
      --text: #1a1a18;
      --text2: #5F5E5A;
      --text3: #888780;
      --radius: 8px;
      --radius-lg: 12px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1a1a18;
        --surface: #242422;
        --border: rgba(255,255,255,0.1);
        --border-md: rgba(255,255,255,0.18);
        --text: #F1EFE8;
        --text2: #B4B2A9;
        --text3: #888780;
        --c1l: #042C53;
        --c1t: #B5D4F4;
        --c2l: #04342C;
        --c2t: #9FE1CB;
        --crl: #501313;
        --cal: #412402;
        --cgl: #173404;
      }
    }

    html, body { height: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; font-size: 14px; color: var(--text); background: var(--bg); line-height: 1.5; }

    /* ── Layout ── */
    .app { display: flex; height: 100vh; overflow: hidden; }
    .sidebar { width: 220px; background: var(--surface); border-right: 0.5px solid var(--border); display: flex; flex-direction: column; flex-shrink: 0; }
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }
    .topbar { padding: 14px 20px; background: var(--surface); border-bottom: 0.5px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
    .topbar h1 { font-size: 16px; font-weight: 500; }
    .topbar-right { display: flex; align-items: center; gap: 10px; }
    .content { flex: 1; overflow-y: auto; padding: 20px; }

    /* ── Sidebar ── */
    .sidebar-logo { padding: 18px 16px 12px; border-bottom: 0.5px solid var(--border); }
    .sidebar-logo h2 { font-size: 15px; font-weight: 600; color: var(--c1); }
    .sidebar-logo p { font-size: 11px; color: var(--text2); margin-top: 1px; }
    .sidebar-user { padding: 10px 16px; border-bottom: 0.5px solid var(--border); display: flex; align-items: center; gap: 8px; }
    .avatar { width: 30px; height: 30px; border-radius: 50%; background: var(--c1l); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: var(--c1t); flex-shrink: 0; }
    .avatar.adm { background: #F5C4B3; color: #993C1D; }
    .user-info p { font-size: 12px; font-weight: 500; }
    .badge-role { font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 500; display: inline-block; margin-top: 2px; }
    .badge-adm { background: #F5C4B3; color: #993C1D; }
    .badge-col { background: var(--c1l); color: var(--c1t); }
    .nav { flex: 1; padding: 8px 0; overflow-y: auto; }
    .nav-section { padding: 8px 16px 3px; font-size: 10px; font-weight: 500; color: var(--text3); text-transform: uppercase; letter-spacing: .05em; }
    .nav-item { display: flex; align-items: center; gap: 8px; padding: 7px 16px; font-size: 13px; cursor: pointer; color: var(--text2); border-left: 2px solid transparent; transition: all .12s; user-select: none; }
    .nav-item:hover { background: var(--bg); color: var(--text); }
    .nav-item.active { background: var(--c1l); color: var(--c1t); border-left-color: var(--c1); font-weight: 500; }
    .nav-item svg { width: 14px; height: 14px; flex-shrink: 0; }
    .sidebar-footer { padding: 10px 16px; border-top: 0.5px solid var(--border); }
    .btn-switch { width: 100%; padding: 6px; font-size: 11px; border: 0.5px solid var(--border-md); border-radius: var(--radius); background: transparent; cursor: pointer; color: var(--text2); font-family: inherit; }
    .btn-switch:hover { background: var(--bg); }

    /* ── Buttons ── */
    .btn { padding: 7px 14px; border-radius: var(--radius); font-size: 13px; cursor: pointer; border: 0.5px solid var(--border-md); background: var(--surface); color: var(--text); font-family: inherit; transition: background .12s; }
    .btn:hover { background: var(--bg); }
    .btn-primary { background: var(--c1); color: #fff; border-color: var(--c1); }
    .btn-primary:hover { background: var(--c1t); }
    .btn-success { background: var(--c2); color: #fff; border-color: var(--c2); }
    .btn-success:hover { background: var(--c2t); }
    .btn-danger { background: var(--cr); color: #fff; border-color: var(--cr); }
    .btn-danger:hover { filter: brightness(0.9); }
    .btn-sm { padding: 4px 10px; font-size: 12px; }

    /* ── Grid ── */
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    .grid4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

    /* ── Cards ── */
    .card { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 16px; margin-bottom: 14px; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .card-title { font-size: 13px; font-weight: 500; color: var(--text2); }

    /* ── Metrics ── */
    .metric { background: var(--bg); border-radius: var(--radius); padding: 12px 14px; }
    .metric-label { font-size: 11px; color: var(--text2); margin-bottom: 4px; }
    .metric-value { font-size: 22px; font-weight: 500; }
    .metric-sub { font-size: 11px; color: var(--text2); margin-top: 2px; }
    .metric-pos { color: var(--cg); }
    .metric-neg { color: var(--cr); }
    .metric-neu { color: var(--c1); }
    .metric-warn { color: var(--ca); }

    /* ── Tags ── */
    .tag { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; }
    .tag-ok { background: var(--c2l); color: var(--c2t); }
    .tag-warn { background: var(--cal); color: #633806; }
    .tag-err { background: var(--crl); color: var(--cr); }
    .tag-neu { background: var(--c1l); color: var(--c1t); }
    .tag-gray { background: var(--bg); color: var(--text2); border: 0.5px solid var(--border); }

    /* ── Tables ── */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { text-align: left; padding: 8px 10px; font-size: 11px; font-weight: 500; color: var(--text2); border-bottom: 0.5px solid var(--border); white-space: nowrap; }
    td { padding: 9px 10px; border-bottom: 0.5px solid var(--border); }
    tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: var(--bg); }
    .table-wrap { overflow-x: auto; }

    /* ── Forms ── */
    .form-group { margin-bottom: 14px; }
    .form-label { display: block; font-size: 12px; font-weight: 500; margin-bottom: 5px; color: var(--text2); }
    input[type=text], input[type=time], input[type=date], input[type=number],
    input[type=email], input[type=password], select, textarea {
      width: 100%; padding: 7px 10px; border: 0.5px solid var(--border-md); border-radius: var(--radius);
      font-size: 13px; font-family: inherit; background: var(--surface); color: var(--text);
    }
    input:focus, select:focus, textarea:focus { outline: none; border-color: var(--c1); box-shadow: 0 0 0 2px rgba(24,95,165,.12); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .form-row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

    /* ── Alerts ── */
    .alert { padding: 10px 14px; border-radius: var(--radius); font-size: 13px; margin-bottom: 12px; }
    .alert-warn { background: var(--cal); color: #633806; border-left: 3px solid var(--ca); }
    .alert-ok { background: var(--c2l); color: var(--c2t); border-left: 3px solid var(--c2); }
    .alert-err { background: var(--crl); color: var(--cr); border-left: 3px solid var(--cr); }
    .alert a { color: inherit; font-weight: 500; }

    /* ── Progress ── */
    .progress-bar { height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden; margin-top: 6px; }
    .progress-fill { height: 100%; border-radius: 3px; transition: width .4s; }
    .fill-ok { background: var(--c2); }
    .fill-warn { background: var(--ca); }
    .fill-err { background: var(--cr); }
    .fill-neu { background: var(--c1); }

    /* ── Tabs ── */
    .tabs { display: flex; gap: 0; margin-bottom: 16px; border-bottom: 0.5px solid var(--border); }
    .tab { padding: 8px 16px; font-size: 13px; cursor: pointer; color: var(--text2); border-bottom: 2px solid transparent; margin-bottom: -0.5px; user-select: none; }
    .tab:hover { color: var(--text); }
    .tab.active { color: var(--c1); border-bottom-color: var(--c1); font-weight: 500; }

    /* ── Login ── */
    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-box { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 32px; width: 380px; }
    .login-logo { text-align: center; margin-bottom: 24px; }
    .login-logo h1 { font-size: 22px; font-weight: 600; color: var(--c1); margin-top: 10px; }
    .login-logo p { font-size: 13px; color: var(--text2); margin-top: 4px; }
    .clock-icon { width: 52px; height: 52px; border-radius: 14px; background: var(--c1l); display: flex; align-items: center; justify-content: center; margin: 0 auto; }
    .demo-block { margin-top: 18px; background: var(--bg); border-radius: var(--radius); padding: 12px; font-size: 12px; color: var(--text2); }
    .demo-block b { font-weight: 500; color: var(--text); display: block; margin-bottom: 4px; }

    /* ── Timeline ── */
    .timeline { display: flex; align-items: flex-start; gap: 0; margin: 20px 0; }
    .tl-step { flex: 1; text-align: center; }
    .tl-dot { width: 30px; height: 30px; border-radius: 50%; border: 2px solid var(--border-md); background: var(--surface); display: flex; align-items: center; justify-content: center; margin: 0 auto; font-size: 11px; font-weight: 600; color: var(--text2); }
    .tl-dot.done { background: var(--c2); border-color: var(--c2); color: #fff; }
    .tl-dot.active { background: var(--c1l); border-color: var(--c1); color: var(--c1t); }
    .tl-connector { flex: 1; height: 2px; background: var(--border); margin-top: 14px; }
    .tl-connector.done { background: var(--c2); }
    .tl-label { font-size: 10px; color: var(--text2); margin-top: 5px; }
    .tl-time { font-size: 12px; font-weight: 500; color: var(--text); margin-top: 2px; }

    /* ── Divider ── */
    .divider { border: none; border-top: 0.5px solid var(--border); margin: 14px 0; }

    /* ── Modal ── */
    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: flex; align-items: center; justify-content: center; z-index: 200; }
    .modal { background: var(--surface); border-radius: var(--radius-lg); padding: 24px; width: 480px; max-width: 95vw; max-height: 88vh; overflow-y: auto; box-shadow: 0 8px 32px rgba(0,0,0,.15); }
    .modal-title { font-size: 15px; font-weight: 500; margin-bottom: 16px; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 8px; margin-top: 20px; padding-top: 14px; border-top: 0.5px solid var(--border); }

    /* ── Calendar ── */
    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; margin-top: 10px; }
    .cal-day-name { font-size: 10px; font-weight: 500; color: var(--text2); text-align: center; padding: 4px 0; }
    .cal-day { min-height: 54px; border-radius: var(--radius); border: 0.5px solid var(--border); padding: 4px 6px; font-size: 11px; cursor: pointer; }
    .cal-day:hover { background: var(--bg); }
    .cal-day.folga { background: var(--cal); border-color: var(--ca); }
    .cal-day.worked { border-left: 2px solid var(--c2); }
    .cal-day.deficit { border-left: 2px solid var(--ca); }
    .cal-day.empty { background: none; border-color: transparent; cursor: default; }
    .cal-day-num { font-weight: 500; }
    .cal-day-hrs { font-size: 10px; color: var(--text2); margin-top: 2px; }

    /* ── Toast ── */
    #toast { position: fixed; bottom: 24px; right: 24px; background: var(--c2); color: #fff; padding: 10px 18px; border-radius: var(--radius); font-size: 13px; z-index: 300; opacity: 0; transition: opacity .25s; pointer-events: none; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .sidebar { width: 180px; }
      .grid4 { grid-template-columns: 1fr 1fr; }
      .grid3 { grid-template-columns: 1fr 1fr; }
      .form-row3 { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .sidebar { display: none; }
      .grid2, .grid3, .grid4 { grid-template-columns: 1fr; }
    }

    .hidden { display: none !important; }
    .mb0 { margin-bottom: 0; }
    .mt8 { margin-top: 8px; }
    .mt12 { margin-top: 12px; }
    .space-between { display: flex; align-items: center; justify-content: space-between; }
    .flex-gap { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

    /* ── Mês accordion ── */
    .mes-folder { border: 0.5px solid var(--border); border-radius: var(--radius-lg); margin-bottom: 10px; overflow: hidden; background: var(--surface); }
    .mes-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; cursor: pointer; user-select: none; background: var(--surface); }
    .mes-header:hover { background: var(--bg); }
    .mes-header-left { display: flex; align-items: center; gap: 10px; }
    .mes-icon { width: 32px; height: 32px; border-radius: var(--radius); background: var(--c1l); display: flex; align-items: center; justify-content: center; color: var(--c1t); font-size: 13px; font-weight: 600; flex-shrink: 0; }
    .mes-title { font-size: 14px; font-weight: 500; }
    .mes-meta { font-size: 11px; color: var(--text2); margin-top: 1px; }
    .mes-stats { display: flex; gap: 16px; align-items: center; }
    .mes-stat { text-align: right; }
    .mes-stat-val { font-size: 13px; font-weight: 500; }
    .mes-stat-lbl { font-size: 10px; color: var(--text2); }
    .mes-chevron { color: var(--text3); transition: transform .2s; font-size: 12px; }
    .mes-chevron.open { transform: rotate(180deg); }
    .mes-body { border-top: 0.5px solid var(--border); }
    .mes-body.collapsed { display: none; }

    /* dia row dentro do mês */
    .dia-row { border-bottom: 0.5px solid var(--border); }
    .dia-row:last-child { border-bottom: none; }
    .dia-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; cursor: pointer; }
    .dia-header:hover { background: var(--bg); }
    .dia-header-left { display: flex; align-items: center; gap: 10px; }
    .dia-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .dia-dot.pos { background: var(--cg); }
    .dia-dot.neg { background: var(--cr); }
    .dia-dot.neu { background: var(--text3); }
    .dia-date { font-size: 13px; font-weight: 500; min-width: 85px; }
    .dia-user { font-size: 12px; color: var(--text2); }
    .dia-hours { font-size: 13px; font-weight: 500; }
    .dia-actions { display: flex; align-items: center; gap: 6px; }
    .dia-detail { padding: 10px 16px 14px 40px; background: var(--bg); display: none; }
    .dia-detail.open { display: block; }
    .dia-timeline { display: flex; gap: 0; align-items: flex-start; margin-bottom: 10px; }
    .dia-tl-step { flex: 1; text-align: center; }
    .dia-tl-dot { width: 24px; height: 24px; border-radius: 50%; background: var(--c2); display: flex; align-items: center; justify-content: center; margin: 0 auto; font-size: 9px; font-weight: 600; color: #fff; }
    .dia-tl-line { flex: 1; height: 2px; background: var(--c2); margin-top: 11px; }
    .dia-tl-label { font-size: 9px; color: var(--text2); margin-top: 3px; }
    .dia-tl-time { font-size: 11px; font-weight: 500; }
    .dia-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 8px; }
    .dia-metric { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius); padding: 8px 10px; }
    .dia-metric-lbl { font-size: 10px; color: var(--text2); }
    .dia-metric-val { font-size: 14px; font-weight: 500; margin-top: 2px; }
    .badge-admin { background: #F5C4B3; color: #993C1D; font-size: 9px; padding: 2px 6px; border-radius: 4px; font-weight: 500; }
  </style>
</head>
<body>

<div id="app"></div>
<div id="toast"></div>

<script>
'use strict';

/* ═══════════════════════════════════════════════
   DATA STORE  (localStorage-backed)
═══════════════════════════════════════════════ */
const Store = (() => {
  const KEY = 'jornada_app_v1';
  const defaults = {
    users: [
      { id: 1, name: 'Admin Sistema', email: 'admin@empresa.com', password: 'admin123', role: 'admin', avatar: 'AS' },
      { id: 2, name: 'Ana Lima',      email: 'ana@empresa.com',   password: 'ana123',   role: 'colaborador', avatar: 'AL', jornadaDiaria: 8, jornadaSemanal: 40, jornadaMensal: 176 },
      { id: 3, name: 'Bruno Souza',   email: 'bruno@empresa.com', password: 'bruno123', role: 'colaborador', avatar: 'BS', jornadaDiaria: 8, jornadaSemanal: 40, jornadaMensal: 176 },
      { id: 4, name: 'Carla Mendes',  email: 'carla@empresa.com', password: 'carla123', role: 'colaborador', avatar: 'CM', jornadaDiaria: 6, jornadaSemanal: 30, jornadaMensal: 132 },
    ],
    registros: [
      { id: 1,  userId: 2, data: '2025-03-24', inicio: '08:02', pausaInicio: '12:00', pausaRetorno: '13:05', fim: '17:15', obs: '',               totalTrab: 7.717, metaDiaria: 8, extras: 0,    devedoras: 0.283, saldo: -0.283, status: 'fechado' },
      { id: 2,  userId: 2, data: '2025-03-25', inicio: '07:45', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '17:30', obs: '',               totalTrab: 8.75,  metaDiaria: 8, extras: 0.75, devedoras: 0,     saldo: 0.75,   status: 'fechado' },
      { id: 3,  userId: 2, data: '2025-03-26', inicio: '08:00', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '18:00', obs: 'Reunião extra',  totalTrab: 9,     metaDiaria: 8, extras: 1,    devedoras: 0,     saldo: 1,      status: 'fechado' },
      { id: 4,  userId: 2, data: '2025-03-27', inicio: '08:15', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '16:45', obs: '',               totalTrab: 7.5,   metaDiaria: 8, extras: 0,    devedoras: 0.5,   saldo: -0.5,   status: 'fechado' },
      { id: 5,  userId: 2, data: '2025-03-28', inicio: '08:00', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '17:00', obs: '',               totalTrab: 8,     metaDiaria: 8, extras: 0,    devedoras: 0,     saldo: 0,      status: 'fechado' },
      { id: 6,  userId: 3, data: '2025-03-24', inicio: '09:00', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '18:30', obs: '',               totalTrab: 8.5,   metaDiaria: 8, extras: 0.5,  devedoras: 0,     saldo: 0.5,    status: 'fechado' },
      { id: 7,  userId: 3, data: '2025-03-25', inicio: '09:00', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '17:00', obs: '',               totalTrab: 7,     metaDiaria: 8, extras: 0,    devedoras: 1,     saldo: -1,     status: 'fechado' },
      { id: 8,  userId: 4, data: '2025-03-24', inicio: '08:00', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '14:00', obs: '',               totalTrab: 5,     metaDiaria: 6, extras: 0,    devedoras: 1,     saldo: -1,     status: 'fechado' },
      { id: 9,  userId: 4, data: '2025-03-25', inicio: '08:00', pausaInicio: '12:00', pausaRetorno: '13:00', fim: '15:30', obs: '',               totalTrab: 6.5,   metaDiaria: 6, extras: 0.5,  devedoras: 0,     saldo: 0.5,    status: 'fechado' },
    ],
    folgas: [
      { id: 1, userId: 2, data: '2025-04-18', tipo: 'Compensatória', horas: 8, status: 'aprovada' },
      { id: 2, userId: 3, data: '2025-04-21', tipo: 'Compensatória', horas: 8, status: 'pendente' },
    ],
    ajustes: [
      { id: 1, userId: 3, data: '2025-03-20', horas: 2, motivo: 'Migração banco de horas — planilha anterior', adminId: 1 },
    ],
    nextId: { users: 5, registros: 10, folgas: 3, ajustes: 2 },
  };

  let data = null;

  function load() {
    try {
      const raw = localStorage.getItem(KEY);
      data = raw ? JSON.parse(raw) : JSON.parse(JSON.stringify(defaults));
    } catch (e) {
      data = JSON.parse(JSON.stringify(defaults));
    }
  }

  function save() {
    try { localStorage.setItem(KEY, JSON.stringify(data)); } catch(e) {}
  }

  function get() { return data; }

  function nextId(collection) {
    const id = data.nextId[collection]++;
    save();
    return id;
  }

  function reset() {
    data = JSON.parse(JSON.stringify(defaults));
    save();
  }

  load();
  return { get, save, nextId, reset };
})();


/* ═══════════════════════════════════════════════
   UTILITIES
═══════════════════════════════════════════════ */
function toMin(t) {
  const [h, m] = t.split(':').map(Number);
  return h * 60 + m;
}

function calcTrab(inicio, pausaInicio, pausaRetorno, fim) {
  const pausa = toMin(pausaRetorno) - toMin(pausaInicio);
  const total = toMin(fim) - toMin(inicio) - pausa;
  return total / 60;
}

function fmt(h) {
  const abs = Math.abs(h);
  const hh = Math.floor(abs);
  const mm = Math.round((abs - hh) * 60);
  if (hh === 0 && mm === 0) return '0min';
  const sign = h < 0 ? '-' : '';
  return sign + (hh > 0 ? hh + 'h' : '') + (mm > 0 ? (hh > 0 ? ' ' : '') + mm + 'min' : '');
}

function dateBR(d) { return d.split('-').reverse().join('/'); }

function today() {
  const d = new Date();
  return d.toISOString().split('T')[0];
}

function calcBanco(userId) {
  const db = Store.get();
  const regs = db.registros.filter(r => r.userId === userId);
  const extras   = regs.reduce((a, r) => a + r.extras,    0);
  const devidas  = regs.reduce((a, r) => a + r.devedoras, 0);
  const ajustes  = db.ajustes.filter(a => a.userId === userId).reduce((a, aj) => a + aj.horas, 0);
  const folgasUsadas = db.folgas.filter(f => f.userId === userId && f.status === 'aprovada').reduce((a, f) => a + f.horas, 0);
  const saldo = extras - devidas + ajustes - folgasUsadas;
  return { extras, devidas, ajustes, folgasUsadas, saldo };
}

function initials(name) {
  return name.split(' ').map(p => p[0]).slice(0, 2).join('').toUpperCase();
}

function esc(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

let toastTimer;
function toast(msg, type = 'ok') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.style.background = type === 'err' ? 'var(--cr)' : type === 'warn' ? 'var(--ca)' : 'var(--c2)';
  el.style.opacity = '1';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.style.opacity = '0'; }, 3000);
}


