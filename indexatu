function renderAdminLancar() {
  const db = Store.get();
  const cols = db.users.filter(u => u.role === 'colaborador');
  const d = App.adminLanc || {};

  // live preview calculation
  let preview = '';
  if (d.userId && d.data && d.inicio && d.pausaInicio && d.pausaRetorno && d.fim) {
    const u = db.users.find(u => u.id === parseInt(d.userId));
    const meta = parseFloat(d.metaDiaria) || u?.jornadaDiaria || 8;
    const total = calcTrab(d.inicio, d.pausaInicio, d.pausaRetorno, d.fim);
    const saldo = total - meta;
    // duplicate warning
    const existe = db.registros.find(r => r.userId === parseInt(d.userId) && r.data === d.data);
    preview = `
      ${existe ? `<div class="alert alert-warn">Já existe um registro para ${u?.name||'este colaborador'} em ${dateBR(d.data)}. Salvar criará um segundo lançamento neste dia.</div>` : ''}
      <div class="card" style="margin-bottom:0">
        <div class="card-title" style="margin-bottom:10px">Prévia do cálculo</div>
        <div class="grid4">
          <div class="metric"><div class="metric-label">Total trabalhado</div><div class="metric-value">${fmt(total)}</div></div>
          <div class="metric"><div class="metric-label">Meta do dia</div><div class="metric-value">${meta}h</div></div>
          <div class="metric"><div class="metric-label">Horas extras</div><div class="metric-value metric-pos">${Math.max(0,saldo)>0?'+'+fmt(Math.max(0,saldo)):'—'}</div></div>
          <div class="metric"><div class="metric-label">Horas devedoras</div><div class="metric-value metric-neg">${Math.max(0,-saldo)>0?'-'+fmt(Math.max(0,-saldo)):'—'}</div></div>
        </div>
      </div>`;
  }

  return `
    <div style="max-width:580px">
      <div class="alert alert-warn" style="margin-bottom:14px">
        Lançamento administrativo — pode ser feito para qualquer colaborador, qualquer data (incluindo datas passadas). Múltiplos lançamentos por dia são permitidos.
      </div>
      <div class="card">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Colaborador</label>
            <select id="al-col" onchange="updateAdminLanc()">
              <option value="">Selecione...</option>
              ${cols.map(c => `<option value="${c.id}" ${d.userId==c.id?'selected':''}>${esc(c.name)}</option>`).join('')}
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Data</label>
            <input type="date" id="al-data" value="${d.data||today()}" onchange="updateAdminLanc()"/>
          </div>
        </div>
        <div class="form-row" style="margin-top:4px">
          <div class="form-group">
            <label class="form-label">Meta do dia (h) <span style="color:var(--text3);font-weight:400">— preenchida automaticamente</span></label>
            <input type="number" step="0.5" id="al-meta" value="${d.metaDiaria||8}" onchange="updateAdminLanc()"/>
          </div>
        </div>
        <hr class="divider"/>
        <div class="form-row3">
          <div class="form-group"><label class="form-label">Início</label><input type="time" id="al-ini" value="${d.inicio||'08:00'}" onchange="updateAdminLanc()"/></div>
          <div class="form-group"><label class="form-label">Início pausa</label><input type="time" id="al-pi" value="${d.pausaInicio||'12:00'}" onchange="updateAdminLanc()"/></div>
          <div class="form-group"><label class="form-label">Retorno pausa</label><input type="time" id="al-pr" value="${d.pausaRetorno||'13:00'}" onchange="updateAdminLanc()"/></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Finalização</label><input type="time" id="al-fim" value="${d.fim||'17:00'}" onchange="updateAdminLanc()"/></div>
          <div class="form-group"><label class="form-label">Observação</label><input type="text" id="al-obs" value="${esc(d.obs||'')}" placeholder="Opcional..."/></div>
        </div>
        <div style="display:flex;gap:8px;margin-top:4px">
          <button class="btn btn-primary" onclick="salvarAdminLanc()">Salvar lançamento</button>
          <button class="btn" onclick="App.adminLanc={};go('admin-registros')">Cancelar</button>
        </div>
      </div>
      ${preview}
    </div>`;
}

function updateAdminLanc() {
  const db = Store.get();
  const uid = parseInt(document.getElementById('al-col')?.value) || 0;
  const u = uid ? db.users.find(u => u.id === uid) : null;
  // Auto-fill meta when collaborator changes
  if (u && !App.adminLanc?.metaManual) {
    const metaEl = document.getElementById('al-meta');
    if (metaEl) metaEl.value = u.jornadaDiaria;
  }
  App.adminLanc = {
    userId:       document.getElementById('al-col')?.value || '',
    data:         document.getElementById('al-data')?.value || today(),
    metaDiaria:   document.getElementById('al-meta')?.value || '8',
    inicio:       document.getElementById('al-ini')?.value  || '08:00',
    pausaInicio:  document.getElementById('al-pi')?.value   || '12:00',
    pausaRetorno: document.getElementById('al-pr')?.value   || '13:00',
    fim:          document.getElementById('al-fim')?.value  || '17:00',
    obs:          document.getElementById('al-obs')?.value  || '',
  };
  // re-render preview only (avoid losing focus by full render)
  // We do a targeted re-render just of this page
  const content = document.querySelector('.content');
  if (content) content.innerHTML = renderAdminLancar();
}

function salvarAdminLanc() {
  const db = Store.get();
  const uid   = parseInt(document.getElementById('al-col')?.value);
  const data  = document.getElementById('al-data')?.value;
  const meta  = parseFloat(document.getElementById('al-meta')?.value) || 8;
  const ini   = document.getElementById('al-ini')?.value;
  const pi    = document.getElementById('al-pi')?.value;
  const pr    = document.getElementById('al-pr')?.value;
  const fim   = document.getElementById('al-fim')?.value;
  const obs   = document.getElementById('al-obs')?.value || '';

  if (!uid || !data || !ini || !pi || !pr || !fim) { toast('Preencha todos os campos obrigatórios.', 'err'); return; }

  const total = calcTrab(ini, pi, pr, fim);
  if (total <= 0) { toast('Horários inválidos — total trabalhado não pode ser negativo.', 'err'); return; }

  db.registros.push({
    id:            Store.nextId('registros'),
    userId:        uid,
    data,
    inicio:        ini,
    pausaInicio:   pi,
    pausaRetorno:  pr,
    fim,
    obs,
    totalTrab:     total,
    metaDiaria:    meta,
    extras:        Math.max(0, total - meta),
    devedoras:     Math.max(0, meta - total),
    saldo:         total - meta,
    status:        'fechado',
    lancadoPorAdmin: true,
  });
  Store.save();
  App.adminLanc = {};
  toast('Lançamento salvo com sucesso!');
  go('admin-registros');
}

function salvarEditReg(rid) {
  const db = Store.get();
  const r = db.registros.find(r => r.id === rid);
  if (!r) return;
  const ini  = document.getElementById('er-inicio').value;
  const pIni = document.getElementById('er-pausa').value;
  const pRet = document.getElementById('er-retorno').value;
  const fim  = document.getElementById('er-fim').value;
  const meta = parseFloat(document.getElementById('er-meta').value) || r.metaDiaria;
  const obs  = document.getElementById('er-obs').value;
  const novaData = document.getElementById('er-data')?.value || r.data;
  const novoUid  = parseInt(document.getElementById('er-col')?.value) || r.userId;

  const total = calcTrab(ini, pIni, pRet, fim);
  if (total <= 0) { toast('Horários inválidos.', 'err'); return; }

  r.userId       = novoUid;
  r.data         = novaData;
  r.inicio       = ini;
  r.pausaInicio  = pIni;
  r.pausaRetorno = pRet;
  r.fim          = fim;
  r.totalTrab    = total;
  r.metaDiaria   = meta;
  r.extras       = Math.max(0, total - meta);
  r.devedoras    = Math.max(0, meta - total);
  r.saldo        = total - meta;
  r.obs          = obs;
  r.lancadoPorAdmin = true;
  Store.save();
  closeModal();
  toast('Registro atualizado!');
}

function salvarAjuste() {
  const db = Store.get();
  const uid   = parseInt(document.getElementById('aj-col').value);
  const data  = document.getElementById('aj-data').value;
  const horas = parseFloat(document.getElementById('aj-horas').value);
  const motivo= document.getElementById('aj-motivo').value.trim();
  if (!uid || !data || isNaN(horas) || !motivo) { toast('Preencha todos os campos.', 'err'); return; }
  db.ajustes.push({ id: Store.nextId('ajustes'), userId: uid, data, horas, motivo, adminId: App.user.id });
  Store.save();
  closeModal();
  toast('Ajuste manual registrado!');
}


