function exportRelatorio() {
  const db = Store.get();
  const rows = [['Colaborador','Data','Total (h)','Meta (h)','Extras (h)','Devedoras (h)','Saldo (h)']];
  db.registros.forEach(r => {
    const u = db.users.find(u => u.id === r.userId);
    rows.push([u?.name||'', r.data, r.totalTrab.toFixed(2), r.metaDiaria, r.extras.toFixed(2), r.devedoras.toFixed(2), r.saldo.toFixed(2)]);
  });
  App.exportCSV(rows, 'relatorio_jornada.csv');
  toast('Relatório exportado!');
}


