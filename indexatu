// which month-folders are open (keyed by 'YYYY-MM')
const openMeses = new Set(['2025-03','2025-04']);
// which dia rows are expanded (keyed by reg.id)
const openDias = new Set();

function toggleMes(ym) {
  if (openMeses.has(ym)) openMeses.delete(ym); else openMeses.add(ym);
  // toggle DOM without full re-render for perf
  const body = document.getElementById('mes-body-' + ym);
  const chev = document.getElementById('mes-chev-' + ym);
  if (!body) return;
  body.classList.toggle('collapsed', !openMeses.has(ym));
  chev.classList.toggle('open', openMeses.has(ym));
}

function toggleDia(rid) {
  if (openDias.has(rid)) openDias.delete(rid); else openDias.add(rid);
  const el = document.getElementById('dia-detail-' + rid);
  if (el) el.classList.toggle('open', openDias.has(rid));
}

function renderAdminRegistros() {
  const db = Store.get();
  const cols = db.users.filter(u => u.role === 'colaborador');

  // Filtros
  const fCol = App.regFiltroCol || '';
  const fMes = App.regFiltroMes || '';

  // Agrupar por mês
  const regs = db.registros
    .filter(r => (!fCol || r.userId === parseInt(fCol)) && (!fMes || r.data.startsWith(fMes)))
    .slice().sort((a,b) => b.data.localeCompare(a.data));

  const byMes = {};
  regs.forEach(r => {
    const ym = r.data.slice(0,7);
    if (!byMes[ym]) byMes[ym] = [];
    byMes[ym].push(r);
  });

  const MONTHS = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];

  const folders = Object.keys(byMes).sort((a,b) => b.localeCompare(a)).map(ym => {
    const rgs = byMes[ym];
    const [y, m] = ym.split('-');
    const mesNome = MONTHS[parseInt(m)-1] + ' ' + y;
    const totalH  = rgs.reduce((a,r) => a + r.totalTrab, 0);
    const totalE  = rgs.reduce((a,r) => a + r.extras, 0);
    const totalD  = rgs.reduce((a,r) => a + r.devedoras, 0);
    const saldoM  = totalE - totalD;
    const isOpen  = openMeses.has(ym);

    const diasHTML = rgs.map(r => {
      const u   = db.users.find(u => u.id === r.userId);
      const dot = r.saldo > 0.01 ? 'pos' : r.saldo < -0.01 ? 'neg' : 'neu';
      const isDiaOpen = openDias.has(r.id);
      const adminTag  = r.lancadoPorAdmin ? `<span class="badge-admin">admin</span>` : '';
      return `<div class="dia-row">
        <div class="dia-header" onclick="toggleDia(${r.id})">
          <div class="dia-header-left">
            <div class="dia-dot ${dot}"></div>
            <span class="dia-date">${dateBR(r.data)}</span>
            <span class="dia-user">${u ? esc(u.name.split(' ')[0]) : '?'} ${adminTag}</span>
          </div>
          <div class="dia-actions">
            <span class="dia-hours" style="color:${r.saldo>=0?'var(--cg)':'var(--cr)'}">${r.saldo>=0?'+':''}${fmt(r.saldo)}</span>
            <span style="font-size:12px;color:var(--text2);margin:0 6px">${fmt(r.totalTrab)}</span>
            <button class="btn btn-sm" onclick="event.stopPropagation();openModal('editReg:${r.id}')">Editar</button>
            <button class="btn btn-sm btn-danger" onclick="event.stopPropagation();excluirReg(${r.id})">×</button>
          </div>
        </div>
        <div class="dia-detail${isDiaOpen?' open':''}" id="dia-detail-${r.id}">
          <div class="dia-timeline">
            <div class="dia-tl-step"><div class="dia-tl-dot">▶</div><div class="dia-tl-label">Início</div><div class="dia-tl-time">${r.inicio}</div></div>
            <div class="dia-tl-line"></div>
            <div class="dia-tl-step"><div class="dia-tl-dot">II</div><div class="dia-tl-label">Pausa</div><div class="dia-tl-time">${r.pausaInicio}</div></div>
            <div class="dia-tl-line"></div>
            <div class="dia-tl-step"><div class="dia-tl-dot">▶</div><div class="dia-tl-label">Retorno</div><div class="dia-tl-time">${r.pausaRetorno}</div></div>
            <div class="dia-tl-line"></div>
            <div class="dia-tl-step"><div class="dia-tl-dot">■</div><div class="dia-tl-label">Fim</div><div class="dia-tl-time">${r.fim}</div></div>
          </div>
          <div class="dia-grid">
            <div class="dia-metric"><div class="dia-metric-lbl">Total trabalhado</div><div class="dia-metric-val">${fmt(r.totalTrab)}</div></div>
            <div class="dia-metric"><div class="dia-metric-lbl">Meta do dia</div><div class="dia-metric-val">${r.metaDiaria}h</div></div>
            <div class="dia-metric"><div class="dia-metric-lbl">Horas extras</div><div class="dia-metric-val" style="color:var(--cg)">${r.extras>0?'+'+fmt(r.extras):'—'}</div></div>
            <div class="dia-metric"><div class="dia-metric-lbl">Horas devedoras</div><div class="dia-metric-val" style="color:var(--cr)">${r.devedoras>0?'-'+fmt(r.devedoras):'—'}</div></div>
          </div>
          ${r.obs ? `<p style="font-size:12px;color:var(--text2);margin-top:8px">Obs: ${esc(r.obs)}</p>` : ''}
        </div>
      </div>`;
    }).join('');

    return `<div class="mes-folder">
      <div class="mes-header" onclick="toggleMes('${ym}')">
        <div class="mes-header-left">
          <div class="mes-icon">${m}</div>
          <div>
            <div class="mes-title">${mesNome}</div>
            <div class="mes-meta">${rgs.length} registro(s) · ${fmt(totalH)} trabalhadas</div>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:16px">
          <div class="mes-stats">
            <div class="mes-stat">
              <div class="mes-stat-val" style="color:var(--cg)">+${fmt(totalE)}</div>
              <div class="mes-stat-lbl">extras</div>
            </div>
            <div class="mes-stat">
              <div class="mes-stat-val" style="color:var(--cr)">-${fmt(totalD)}</div>
              <div class="mes-stat-lbl">devedoras</div>
            </div>
            <div class="mes-stat">
              <div class="mes-stat-val" style="color:${saldoM>=0?'var(--cg)':'var(--cr)'};font-size:15px">${saldoM>=0?'+':''}${fmt(saldoM)}</div>
              <div class="mes-stat-lbl">saldo</div>
            </div>
          </div>
          <span class="mes-chevron${isOpen?' open':''}">▼</span>
        </div>
      </div>
      <div class="mes-body${isOpen?'':' collapsed'}" id="mes-body-${ym}">
        ${diasHTML || '<p style="padding:14px 16px;font-size:13px;color:var(--text2)">Nenhum registro neste mês.</p>'}
      </div>
    </div>`;
  });

  const mesesDisponiveis = [...new Set(db.registros.map(r => r.data.slice(0,7)))].sort((a,b)=>b.localeCompare(a));

  return `
    <div class="flex-gap" style="margin-bottom:14px">
      <select id="f-col" style="width:180px" onchange="App.regFiltroCol=this.value;render()">
        <option value="">Todos os colaboradores</option>
        ${cols.map(c => `<option value="${c.id}" ${fCol==c.id?'selected':''}>${esc(c.name)}</option>`).join('')}
      </select>
      <select id="f-mes" style="width:150px" onchange="App.regFiltroMes=this.value;render()">
        <option value="">Todos os meses</option>
        ${mesesDisponiveis.map(ym => {
          const [y,m] = ym.split('-');
          const MONTHS2 = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
          return `<option value="${ym}" ${fMes===ym?'selected':''}>${MONTHS2[parseInt(m)-1]} ${y}</option>`;
        }).join('')}
      </select>
      <button class="btn btn-primary" onclick="go('admin-lancar')">+ Novo lançamento</button>
      <button class="btn" onclick="exportRegistros()">${I.download} CSV</button>
    </div>
    ${folders.length ? folders.join('') : '<div class="card mb0" style="text-align:center;padding:32px;color:var(--text2)">Nenhum lançamento encontrado para os filtros selecionados.</div>'}
  `;
}

function exportRegistros() {
  const db = Store.get();
  const rows = [['Colaborador','Data','Início','Pausa Início','Pausa Retorno','Fim','Total (h)','Meta (h)','Extras (h)','Devedoras (h)','Saldo (h)','Obs']];
  db.registros.forEach(r => {
    const u = db.users.find(u => u.id === r.userId);
    rows.push([u?.name||'', r.data, r.inicio, r.pausaInicio, r.pausaRetorno, r.fim,
      r.totalTrab.toFixed(2), r.metaDiaria, r.extras.toFixed(2), r.devedoras.toFixed(2), r.saldo.toFixed(2), r.obs]);
  });
  App.exportCSV(rows, 'registros_jornada.csv');
  toast('CSV exportado!');
}

function excluirReg(rid) {
  if (!confirm('Excluir este registro? Esta ação não pode ser desfeita.')) return;
  const db = Store.get();
  db.registros = db.registros.filter(r => r.id !== rid);
  Store.save();
  toast('Registro excluído.');
  render();
}

