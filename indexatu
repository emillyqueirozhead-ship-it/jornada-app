/* ═══════════════════════════════════════════════
   ADMIN — FOLGAS
═══════════════════════════════════════════════ */
function renderAdminFolgas() {
  const db = Store.get();
  const DAYS = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const MONTHS = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho','Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
  const ref = new Date(2025, 3, 1); // April 2025
  const month = ref.getMonth(), year = ref.getFullYear();
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const folgasMonth = db.folgas.filter(f => { const d = new Date(f.data); return d.getMonth() === month && d.getFullYear() === year; });

  let cells = '';
  for (let i = 0; i < firstDay; i++) cells += `<div class="cal-day empty"></div>`;
  for (let d = 1; d <= daysInMonth; d++) {
    const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dow = (firstDay + d - 1) % 7;
    const isWeekend = dow === 0 || dow === 6;
    const folga = folgasMonth.find(f => f.data === ds);
    const reg = db.registros.find(r => r.data === ds);
    if (isWeekend) { cells += `<div class="cal-day empty" style="background:var(--bg)"><div class="cal-day-num" style="color:var(--text3)">${d}</div></div>`; }
    else if (folga) {
      const u = db.users.find(u => u.id === folga.userId);
      cells += `<div class="cal-day folga" title="${u?.name||''} — ${folga.tipo}">
        <div class="cal-day-num">${d}</div>
        <div class="cal-day-hrs">${u?.avatar||''} folga</div>
      </div>`;
    } else if (reg) {
      const cls = reg.saldo >= 0 ? 'worked' : 'deficit';
      cells += `<div class="cal-day ${cls}"><div class="cal-day-num">${d}</div><div class="cal-day-hrs">${fmt(reg.totalTrab)}</div></div>`;
    } else {
      cells += `<div class="cal-day"><div class="cal-day-num">${d}</div></div>`;
    }
  }

  return `
    <div class="space-between" style="margin-bottom:14px">
      <h2 style="font-size:15px;font-weight:500">${MONTHS[month]} ${year}</h2>
      <button class="btn btn-primary" onclick="openModal('novaFolga')">+ Registrar folga</button>
    </div>
    <div class="card">
      <div class="cal-grid">
        ${DAYS.map(d => `<div class="cal-day-name">${d}</div>`).join('')}
        ${cells}
      </div>
    </div>
    <div class="card mb0">
      <div class="card-header"><span class="card-title">Folgas registradas</span></div>
      <table>
        <thead><tr><th>Colaborador</th><th>Data</th><th>Tipo</th><th>Horas</th><th>Status</th><th>Ações</th></tr></thead>
        <tbody>
          ${db.folgas.map(f => {
            const u = db.users.find(u => u.id === f.userId);
            return `<tr>
              <td>${u ? esc(u.name) : '?'}</td>
              <td>${dateBR(f.data)}</td>
              <td>${f.tipo}</td>
              <td>${f.horas}h</td>
              <td><span class="tag ${f.status==='aprovada'?'tag-ok':f.status==='pendente'?'tag-warn':'tag-err'}">${f.status}</span></td>
              <td>
                ${f.status === 'pendente' ? `<button class="btn btn-sm btn-success" onclick="aprovarFolga(${f.id})">Aprovar</button> ` : ''}
                <button class="btn btn-sm btn-danger" onclick="recusarFolga(${f.id})">Remover</button>
              </td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>`;
}

function aprovarFolga(fid) {
  const db = Store.get();
  const f = db.folgas.find(f => f.id === fid);
  if (f) { f.status = 'aprovada'; Store.save(); toast('Folga aprovada!'); render(); }
}

function recusarFolga(fid) {
  if (!confirm('Remover este registro de folga?')) return;
  const db = Store.get();
  db.folgas = db.folgas.filter(f => f.id !== fid);
  Store.save();
  toast('Folga removida.');
  render();
}

function salvarFolga() {
  const db = Store.get();
  const uid   = parseInt(document.getElementById('nf-col').value);
  const data  = document.getElementById('nf-data').value;
  const horas = parseFloat(document.getElementById('nf-horas').value) || 8;
  const tipo  = document.getElementById('nf-tipo').value;
  if (!uid || !data) { toast('Preencha todos os campos.', 'err'); return; }
  const banco = calcBanco(uid);
  if (banco.saldo < horas) {
    if (!confirm(`Saldo insuficiente!\nSaldo atual: ${fmt(banco.saldo)}\nFolga solicitada: ${horas}h\n\nDeseja registrar mesmo assim?`)) return;
  }
  db.folgas.push({ id: Store.nextId('folgas'), userId: uid, data, tipo, horas, status: 'aprovada' });
  Store.save();
  closeModal();
  toast('Folga registrada e descontada do banco!');
}


