        <div class="form-row3">
          <div class="form-group">
            <label class="form-label">Jornada diária (h)</label>
            <input type="number" step="0.5" id="j-dia-${c.id}" value="${c.jornadaDiaria}"/>
          </div>
          <div class="form-group">
            <label class="form-label">Jornada semanal (h)</label>
            <input type="number" step="0.5" id="j-sem-${c.id}" value="${c.jornadaSemanal}"/>
          </div>
          <div class="form-group">
            <label class="form-label">Jornada mensal (h)</label>
            <input type="number" step="0.5" id="j-mes-${c.id}" value="${c.jornadaMensal}"/>
          </div>
        </div>
        <button class="btn btn-success" onclick="salvarJornada(${c.id})">Salvar jornada</button>
      </div>
    `).join('')}`;
}

function salvarJornada(uid) {
  const db = Store.get();
  const u = db.users.find(u => u.id === uid);
  if (!u) return;
  u.jornadaDiaria  = parseFloat(document.getElementById(`j-dia-${uid}`).value) || u.jornadaDiaria;
  u.jornadaSemanal = parseFloat(document.getElementById(`j-sem-${uid}`).value) || u.jornadaSemanal;
  u.jornadaMensal  = parseFloat(document.getElementById(`j-mes-${uid}`).value) || u.jornadaMensal;
  Store.save();
  toast('Jornada atualizada!');
}


