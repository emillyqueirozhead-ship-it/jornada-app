function renderColLancar() {
  const db = Store.get();
  const u = App.user;
  const jaLancou = db.registros.some(r => r.userId === u.id && r.data === today());

  if (jaLancou) {
    const r = db.registros.find(r => r.userId === u.id && r.data === today());
    return `<div style="max-width:480px">
      <div class="alert alert-ok" style="margin-bottom:14px">Jornada de hoje já registrada. Lançamentos não podem ser editados após o envio.</div>
      <div class="card mb0">
        <div class="card-header"><span class="card-title">Registro de ${dateBR(r.data)}</span></div>
        <div class="timeline">
          <div class="tl-step"><div class="tl-dot done">▶</div><div class="tl-label">Início</div><div class="tl-time">${r.inicio}</div></div>
          <div class="tl-connector done"></div>
          <div class="tl-step"><div class="tl-dot done">II</div><div class="tl-label">Pausa</div><div class="tl-time">${r.pausaInicio}</div></div>
          <div class="tl-connector done"></div>
          <div class="tl-step"><div class="tl-dot done">▶</div><div class="tl-label">Retorno</div><div class="tl-time">${r.pausaRetorno}</div></div>
          <div class="tl-connector done"></div>
          <div class="tl-step"><div class="tl-dot done">■</div><div class="tl-label">Fim</div><div class="tl-time">${r.fim}</div></div>
        </div>
        <hr class="divider"/>
        <div class="grid3">
          <div class="metric"><div class="metric-label">Total trabalhado</div><div class="metric-value">${fmt(r.totalTrab)}</div></div>
          <div class="metric"><div class="metric-label">Meta do dia</div><div class="metric-value">${r.metaDiaria}h</div></div>
          <div class="metric"><div class="metric-label">Saldo do dia</div>
            <div class="metric-value ${r.saldo >= 0 ? 'metric-pos' : 'metric-neg'}">${r.saldo >= 0 ? '+' : ''}${fmt(Math.abs(r.saldo))}</div>
          </div>
        </div>
      </div>
    </div>`;
  }

  const step = App.lancStep;
  const d = App.lancData;
  const steps = ['Início','Pausa','Retorno','Finalização'];

  let preview = '';
  if (step === 3 && d.inicio && d.pausaInicio && d.pausaRetorno) {
    const total = calcTrab(d.inicio, d.pausaInicio, d.pausaRetorno, d.previewFim || '17:00');
    const meta = u.jornadaDiaria;
    const saldo = total - meta;
    preview = `<div class="card mt8">
      <div class="card-title" style="margin-bottom:10px">Prévia do cálculo</div>
      <div class="grid3">
        <div class="metric"><div class="metric-label">Total trabalhado</div><div class="metric-value">${fmt(total)}</div></div>
        <div class="metric"><div class="metric-label">Meta do dia</div><div class="metric-value">${meta}h</div></div>
        <div class="metric"><div class="metric-label">Saldo do dia</div><div class="metric-value ${saldo>=0?'metric-pos':'metric-neg'}">${saldo>=0?'+':''}${fmt(Math.abs(saldo))}</div></div>
      </div>
    </div>`;
  }

  return `<div style="max-width:500px">
    <div class="card">
      <div class="card-header">
        <span class="card-title">Registro de hoje — ${dateBR(today())}</span>
        <span class="tag tag-neu">Jornada: ${u.jornadaDiaria}h</span>
      </div>
      <div class="timeline">
        ${steps.map((s, i) => `
          <div class="tl-step">
            <div class="tl-dot ${step > i ? 'done' : step === i ? 'active' : ''}">${step > i ? '✓' : i + 1}</div>
            <div class="tl-label">${s}</div>
            ${step > i ? `<div class="tl-time">${i===0?d.inicio:i===1?d.pausaInicio:i===2?d.pausaRetorno:d.fim}</div>` : ''}
          </div>
          ${i < 3 ? `<div class="tl-connector${step > i ? ' done' : ''}"></div>` : ''}
        `).join('')}
      </div>
      <hr class="divider"/>
      ${step === 0 ? `
        <div class="form-group"><label class="form-label">Hora de início do expediente</label><input type="time" id="l-ini" value="08:00"/></div>
        <button class="btn btn-primary" onclick="advanceLanc(0)">Confirmar início →</button>
      ` : ''}
      ${step === 1 ? `
        <div class="form-group"><label class="form-label">Hora de início da pausa / almoço</label><input type="time" id="l-pi" value="12:00"/></div>
        <button class="btn btn-primary" onclick="advanceLanc(1)">Confirmar pausa →</button>
      ` : ''}
      ${step === 2 ? `
        <div class="form-group"><label class="form-label">Hora de retorno da pausa</label><input type="time" id="l-pr" value="13:00"/></div>
        <button class="btn btn-primary" onclick="advanceLanc(2)">Confirmar retorno →</button>
      ` : ''}
      ${step === 3 ? `
        <div class="form-group"><label class="form-label">Hora de finalização do expediente</label>
          <input type="time" id="l-fim" value="17:00" oninput="App.lancData.previewFim=this.value;render()"/>
        </div>
        <div class="form-group"><label class="form-label">Observação (opcional)</label>
          <input type="text" id="l-obs" placeholder="Reunião extra, trabalho remoto..."/>
        </div>
        <button class="btn btn-success" onclick="advanceLanc(3)">✓ Finalizar e salvar jornada</button>
      ` : ''}
      ${step === 4 ? `<div class="alert alert-ok mb0">Jornada salva com sucesso! Não é possível editar após o envio.</div>` : ''}
    </div>
    ${preview}
  </div>`;
}

function advanceLanc(step) {
  if (step === 0) {
    App.lancData.inicio = document.getElementById('l-ini').value;
    App.lancStep = 1;
  } else if (step === 1) {
    App.lancData.pausaInicio = document.getElementById('l-pi').value;
    App.lancStep = 2;
  } else if (step === 2) {
    App.lancData.pausaRetorno = document.getElementById('l-pr').value;
    App.lancStep = 3;
  } else if (step === 3) {
    const fim = document.getElementById('l-fim').value;
    const obs = document.getElementById('l-obs').value;
    App.lancData.fim = fim;
    const d = App.lancData;
    const u = App.user;
    const total = calcTrab(d.inicio, d.pausaInicio, d.pausaRetorno, fim);
    const meta = u.jornadaDiaria;

    const db = Store.get();
    db.registros.push({
      id:          Store.nextId('registros'),
      userId:      u.id,
      data:        today(),
      inicio:      d.inicio,
      pausaInicio: d.pausaInicio,
      pausaRetorno:d.pausaRetorno,
      fim,
      obs,
      totalTrab:   total,
      metaDiaria:  meta,
      extras:      Math.max(0, total - meta),
      devedoras:   Math.max(0, meta - total),
      saldo:       total - meta,
      status:      'fechado',
    });
    Store.save();
    App.lancStep = 4;
    App.lancData = {};
    toast('Jornada registrada com sucesso!');
  }
  render();
}


/* ═══════════════════════════════════════════════
   COLABORADOR — HISTÓRICO
═══════════════════════════════════════════════ */
function renderColHistorico() {
  const db = Store.get();
  const regs = db.registros.filter(r => r.userId === App.user.id);
  const banco = calcBanco(App.user.id);

  return `
    <div class="grid3" style="margin-bottom:14px">
      <div class="metric"><div class="metric-label">Horas extras</div><div class="metric-value metric-pos">+${fmt(banco.extras)}</div></div>
      <div class="metric"><div class="metric-label">Horas devedoras</div><div class="metric-value metric-neg">-${fmt(banco.devidas)}</div></div>
      <div class="metric"><div class="metric-label">Saldo do banco</div><div class="metric-value ${banco.saldo>=0?'metric-pos':'metric-neg'}">${banco.saldo>=0?'+':''}${fmt(banco.saldo)}</div></div>
    </div>
    <div class="card mb0">
      <div class="table-wrap">
        <table>
          <thead><tr><th>Data</th><th>Início</th><th>Pausa</th><th>Retorno</th><th>Fim</th><th>Total</th><th>Meta</th><th>Saldo do dia</th></tr></thead>
          <tbody>
            ${regs.slice().reverse().map(r => `<tr>
              <td>${dateBR(r.data)}</td>
              <td>${r.inicio}</td><td>${r.pausaInicio}</td><td>${r.pausaRetorno}</td><td>${r.fim}</td>
              <td>${fmt(r.totalTrab)}</td>
              <td>${r.metaDiaria}h</td>
              <td style="color:${r.saldo>=0?'var(--cg)':'var(--cr)'}">${r.saldo>=0?'+':''}${fmt(Math.abs(r.saldo))}</td>
            </tr>`).join('')}
          </tbody>
        </table>
      </div>
      <p style="font-size:12px;color:var(--text2);margin-top:10px">Lançamentos confirmados não podem ser editados. Em caso de erro, contate o administrador.</p>
    </div>`;
}


/* ═══════════════════════════════════════════════
   MODAIS
═══════════════════════════════════════════════ */
function renderModal() {
  const m = App.modal;
  const db = Store.get();
  let content = '';

  if (m === 'novoCol') {
    content = `<div class="modal-title">Novo colaborador</div>
      <div class="form-group"><label class="form-label">Nome completo</label><input type="text" id="nc-nome" placeholder="Nome Sobrenome"/></div>
      <div class="form-group"><label class="form-label">E-mail</label><input type="email" id="nc-email" placeholder="email@empresa.com"/></div>
      <div class="form-group"><label class="form-label">Senha inicial</label><input type="password" id="nc-pass" placeholder="••••••"/></div>
      <div class="form-row3">
        <div class="form-group"><label class="form-label">Jornada diária (h)</label><input type="number" step="0.5" id="nc-dia" value="8"/></div>
        <div class="form-group"><label class="form-label">Semanal (h)</label><input type="number" step="0.5" id="nc-sem" value="40"/></div>
        <div class="form-group"><label class="form-label">Mensal (h)</label><input type="number" step="0.5" id="nc-mes" value="176"/></div>
      </div>
      <div class="modal-footer">
        <button class="btn" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="salvarNovoCol()">Salvar colaborador</button>
      </div>`;
  }

  else if (m && m.startsWith('editCol:')) {
    const uid = parseInt(m.split(':')[1]);
    const c = db.users.find(u => u.id === uid) || {};
    content = `<div class="modal-title">Editar colaborador — ${esc(c.name||'')}</div>
      <div class="form-group"><label class="form-label">Nome completo</label><input type="text" id="ec-nome" value="${esc(c.name||'')}"/></div>
      <div class="form-group"><label class="form-label">E-mail</label><input type="email" id="ec-email" value="${esc(c.email||'')}"/></div>
      <div class="form-group"><label class="form-label">Nova senha (deixe em branco para manter)</label><input type="password" id="ec-pass" placeholder="••••••"/></div>
      <div class="form-row3">
        <div class="form-group"><label class="form-label">Jornada diária (h)</label><input type="number" step="0.5" id="ec-dia" value="${c.jornadaDiaria||8}"/></div>
        <div class="form-group"><label class="form-label">Semanal (h)</label><input type="number" step="0.5" id="ec-sem" value="${c.jornadaSemanal||40}"/></div>
        <div class="form-group"><label class="form-label">Mensal (h)</label><input type="number" step="0.5" id="ec-mes" value="${c.jornadaMensal||176}"/></div>
      </div>
      <div class="modal-footer">
        <button class="btn" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="salvarEditCol(${uid})">Salvar alterações</button>
      </div>`;
  }

  else if (m && m.startsWith('editReg:')) {
    const rid = parseInt(m.split(':')[1]);
    const r = db.registros.find(r => r.id === rid) || {};
    const u = db.users.find(u => u.id === r.userId);
    const colsOpts = db.users.filter(u=>u.role==='colaborador').map(c =>
      `<option value="${c.id}" ${c.id===r.userId?'selected':''}>${esc(c.name)}</option>`).join('');
    content = `<div class="modal-title">Editar lançamento — ${u ? esc(u.name) : ''} · ${dateBR(r.data||today())}</div>
      <div class="alert alert-warn">Alterações feitas pelo administrador ficam marcadas no histórico.</div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Colaborador</label><select id="er-col">${colsOpts}</select></div>
        <div class="form-group"><label class="form-label">Data</label><input type="date" id="er-data" value="${r.data||today()}"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Hora início</label><input type="time" id="er-inicio" value="${r.inicio||'08:00'}"/></div>
        <div class="form-group"><label class="form-label">Início pausa</label><input type="time" id="er-pausa" value="${r.pausaInicio||'12:00'}"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Retorno pausa</label><input type="time" id="er-retorno" value="${r.pausaRetorno||'13:00'}"/></div>
        <div class="form-group"><label class="form-label">Hora fim</label><input type="time" id="er-fim" value="${r.fim||'17:00'}"/></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Meta diária (h)</label><input type="number" step="0.5" id="er-meta" value="${r.metaDiaria||8}"/></div>
        <div class="form-group"><label class="form-label">Observação</label><input type="text" id="er-obs" value="${esc(r.obs||'')}"/></div>
      </div>
      <div class="modal-footer">
        <button class="btn" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="salvarEditReg(${rid})">Salvar alterações</button>
      </div>`;
  }

  else if (m === 'ajuste') {
    const cols = db.users.filter(u => u.role === 'colaborador');
    content = `<div class="modal-title">Ajuste manual de horas</div>
      <div class="form-group"><label class="form-label">Colaborador</label>
        <select id="aj-col">${cols.map(c => `<option value="${c.id}">${esc(c.name)}</option>`).join('')}</select>
      </div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Data</label><input type="date" id="aj-data" value="${today()}"/></div>
        <div class="form-group"><label class="form-label">Horas (+crédito / −débito)</label><input type="number" step="0.5" id="aj-horas" placeholder="Ex: 2 ou -1.5"/></div>
      </div>
      <div class="form-group"><label class="form-label">Motivo do ajuste (obrigatório)</label><textarea id="aj-motivo" rows="2" placeholder="Descreva o motivo..."></textarea></div>
      <div class="modal-footer">
        <button class="btn" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="salvarAjuste()">Confirmar ajuste</button>
      </div>`;
  }

  else if (m === 'novaFolga') {
    const cols = db.users.filter(u => u.role === 'colaborador');
    content = `<div class="modal-title">Registrar folga compensatória</div>
      <div class="form-group"><label class="form-label">Colaborador</label>
        <select id="nf-col" onchange="checkSaldoFolga()">
          ${cols.map(c => {
            const b = calcBanco(c.id);
            return `<option value="${c.id}">${esc(c.name)} (saldo: ${b.saldo>=0?'+':''}${fmt(b.saldo)})</option>`;
          }).join('')}
        </select>
      </div>
      <div id="nf-saldo-info"></div>
      <div class="form-row">
        <div class="form-group"><label class="form-label">Data da folga</label><input type="date" id="nf-data" value="2025-04-25"/></div>
        <div class="form-group"><label class="form-label">Horas a descontar</label><input type="number" step="0.5" id="nf-horas" value="8" onchange="checkSaldoFolga()"/></div>
      </div>
      <div class="form-group"><label class="form-label">Tipo</label>
        <select id="nf-tipo"><option>Compensatória</option><option>Abono de ponto</option></select>
      </div>
      <div class="modal-footer">
        <button class="btn" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" onclick="salvarFolga()">Registrar folga</button>
      </div>`;
  }

  return `<div class="modal-backdrop" onclick="if(event.target===this)closeModal()">
    <div class="modal">${content}</div>
  </div>`;
}

function checkSaldoFolga() {
  const uid   = parseInt(document.getElementById('nf-col')?.value);
  const horas = parseFloat(document.getElementById('nf-horas')?.value) || 8;
  const el    = document.getElementById('nf-saldo-info');
  if (!el || !uid) return;
  const banco = calcBanco(uid);
  if (banco.saldo < horas) {
    el.innerHTML = `<div class="alert alert-err">Saldo insuficiente! Disponível: ${fmt(banco.saldo)}. A folga de ${fmt(horas)} ultrapassará o saldo.</div>`;
  } else {
    el.innerHTML = `<div class="alert alert-ok">Saldo disponível: ${fmt(banco.saldo)}. Após folga: ${fmt(banco.saldo - horas)}</div>`;
  }
}


/* ═══════════════════════════════════════════════
   BOOT
═══════════════════════════════════════════════ */
render();
</script>
</body>
